ming Pool","Coaching"],"website":"https://nuevaalcantaraclub.com","bookingUrl":"https://playtomic.io","featured":true,"rating":4.3,"reviewCount":317,"image":"https://lh3.googleusercontent.com/gps-cs-s/AHVAweqaM_jFhR6Kv9BopL7_KxxD8VqvvP3D5tZnMqmYKMoEknct7A5BIh0tAwk7h7ANJQDsoAPQCFgJZCJGeARtxK3OPZPH0Ta7Xyz_HMuaU9bju9BdMFcOzJIZlNM6PzUV-oMAoXb6=w800-h500-k-no"},{"slug":"puente-romano-padel","name":"Puente Romano Tennis, Padel & Fitness","area":"Marbella Centro","courts":4,"indoor":false,"outdoor":true,"priceFrom":24,"priceTo":40,"surface":"Artificial Grass","phone":"+34 952 82 61 03","lat":36.5024,"lng":-4.9261,"address":"Conjunto Jardín Andaluz, 4, 29602 Marbella, Málaga","hours":"Daily 08:00–21:00","description":"One of the most exclusive addresses in European padel, Puente Romano's courts sit within the legendary Golden Mile resort where professional players and celebrities come to train. Four premium outdoor courts are complemented by a world-class coaching academy, Michelin-starred dining, and direct beach access — making every game feel like an event in itself.","amenities":["Parking","Showers","Restaurant","Bar","Pro Shop","Racket Rental","Physiotherapy","Gym","Swimming Pool","Spa","Wi-Fi","Coaching"],"website":"https://tenis.puenteromano.com","bookingUrl":"https://playtomic.io/wl/da77891a-43b3-11e8-8674-52540049669c","featured":true,"rating":4.6,"reviewCount":339,"image":"https://lh3.googleusercontent.com/gps-cs-s/AHVAwepf8bKwZ2CCZEKQSXGxaW3D9inxLZFrxK9lUlztbXj4VOuKvi4fLNhZA3_oLxQIWdE7BiYrKpaG5Ii32AHrBV92lKAyOMvf78Uw1KfgBf2RWTb1IftOu9c9p9tWRdU_6gje2nDWCA=w800-h500-k-no"},{"slug":"manolo-santana-racquets-club","name":"Manolo Santana Racquets Club","area":"Nueva Andalucía","courts":4,"indoor":false,"outdoor":true,"priceFrom":16,"priceTo":26,"surface":"Artificial Grass","phone":"+34 952 77 85 80","lat":36.512,"lng":-4.9491,"address":"Carretera de Istán, km 2, 29602 Marbella, Málaga","hours":"Mon–Sat 09:00–22:00, Sun 09:00–17:00","description":"Founded in 1997 by Spain's tennis legend Manolo Santana, this prestigious club in Nueva Andalucía's Golf Valley offers 4 padel courts alongside 6 tennis courts. Regular clinics from WPT-certified coaches, a vibrant restaurant and bar, outdoor swimming pool, and an international member community make this one of the most social clubs on the coast.","amenities":["Parking","Showers","Restaurant","Bar","Pro Shop","Racket Rental","Swimming Pool","Wi-Fi","Coaching"],"website":"https://www.manolosantana.es","bookingUrl":"https://playtomic.com/clubs/manolo-santana-racquets-club-marbella/embed","featured":false,"rating":4.1,"reviewCount":200,"image":"https://lh3.googleusercontent.com/gps-cs-s/AHVAwerH25gAgG_SwyxAYiWM8Rvx2JOfnH4DoGd9rOEDLyLYa3RRbQ9SwsmQUVYkPHfl2yqJx1WtE0hWECoVJGpTXZe72m1T_lHzxVp4GrPeH1sYUxe4tXxz7JJ1Pkcj3UppEr4VHbA5=w800-h500-k-no"},{"slug":"bel-air-tennis-padel","name":"Club de Tenis y Pádel Bel Air","area":"Estepona","courts":4,"indoor":false,"outdoor":true,"priceFrom":12,"priceTo":20,"surface":"Artificial Grass","phone":"+34 952 88 32 21","lat":36.4706,"lng":-5.043,"address":"C. del Tenis, s/n, 29688 Bel-Air, Estepona, Málaga","hours":"Mon–Fri 08:30–22:00, Sat 08:30–20:00, Sun 09:00–17:00","description":"A full-service sports club between Estepona and San Pedro, Bel Air offers 4 padel courts and 9 tennis courts in a relaxed family-friendly setting. With a well-regarded restaurant serving breakfast and lunch, a swimming pool, and a comprehensive coaching academy for juniors and adults, Bel Air is a genuine community club with consistently high Google reviews.","amenities":["Parking","Showers","Restaurant","Bar","Swimming Pool","Wi-Fi","Coaching"],"website":"http://www.belairtennis.com","bookingUrl":"https://playtomic.io","featured":false,"rating":4.6,"reviewCount":258,"image":"https://lh3.googleusercontent.com/gps-cs-s/AHVAwer7gK4fvNfCoScBMQ2tEg4TcXx23b9_pNOmcvCR2hHdC66Ys8R8Cw7tnhQ6WzQMhvqW9YmR87Rmu0GYAoua_2wnjbN7GT0GVUXaM3kdcsjDi6PIeAD0r4KbamyTDhoiACuJ5nVJ=w800-h500-k-no"},{"slug":"aloha-tennis-padel","name":"Aloha Tennis & Padel Club","area":"Nueva Andalucía","courts":4,"indoor":false,"outdoor":true,"priceFrom":12,"priceTo":20,"surface":"Artificial Grass","phone":"+34 685 35 14 09","lat":36.502,"lng":-4.9601,"address":"Calle Paris, 1, Nueva Andalucía, 29660 Marbella, Málaga","hours":"Mon–Sat 09:00–21:30, Sun 09:00–20:00","description":"A well-loved padel and tennis club nestled in the Aloha residential area of Nueva Andalucía. The club has a loyal community of local and expat members, active weekly leagues, and a welcoming atmosphere that keeps players coming back. Conveniently located close to Puerto Banús with easy parking.","amenities":["Parking","Showers","Bar","Racket Rental","Coaching"],"website":"http://alohatennisclub.matchpoint.com.es","bookingUrl":"https://playtomic.io","featured":false,"rating":4.6,"reviewCount":61,"image":"https://lh3.googleusercontent.com/gps-cs-s/AHVAwepXYrXEmngDh-9Eew1XstilzU9WfgDvNk7-fX8qttqgdkwH_GhLd9SzJSKDnnzjBqobCewNktN2EJRdZ8cGElaCaw3z3vsvPQCFT368N29gZurKZq0yTtHqPAnxHV11-C6RNchp=w800-h500-k-no"},{"slug":"international-tennis-club-marbella","name":"International Tennis Club","area":"Marbella Centro","courts":3,"indoor":false,"outdoor":true,"priceFrom":12,"priceTo":18,"surface":"Artificial Grass / Hard","phone":"+34 952 81 33 41","lat":36.4895,"lng":-4.968,"address":"C. Río Elba, 29660 Marbella, Málaga","hours":"Mon–Sat 09:00–20:00, Sun 09:00–14:00","description":"A well-established multi-surface club in central Marbella offering fast hard courts, clay, and padel courts in a unique location. The International Tennis Club has long been a favourite with the international community living in and around Marbella town, combining quality facilities with a relaxed, unpretentious atmosphere.","amenities":["Parking","Showers","Bar","Wi-Fi","Coaching"],"website":"http://clubinternacionalmarbella.es","bookingUrl":"https://playtomic.io","featured":false,"rating":4.4,"reviewCount":70,"image":"https://lh3.googleusercontent.com/gps-cs-s/AHVAwepKGvkvkqyZotl7XMVXbPqRDRoaS9xTuQNi-5iuT7KMKzmooad4zVUykQUxDJKNfPsiQLL-YtjwvDvhKw4VUGdFBISHnCKfl42h2GjjiEPjX5NljNsewfUH2SGSrJtpl5cioXTlQQ=w800-h500-k-no"},{"slug":"royal-tennis-club-marbella","name":"Royal Tennis Club Marbella","area":"Marbella Este","courts":4,"indoor":false,"outdoor":true,"priceFrom":10,"priceTo":18,"surface":"Clay / Artificial Grass","phone":"+34 687 66 50 84","lat":36.5046,"lng":-4.8081,"address":"Carretera de Cádiz, 188, 29604 El Rosario, Marbella, Málaga","hours":"Daily 08:00–22:00","description":"Internationally renowned tennis and padel club set in the El Rosario area, just 800 metres from the beach. Royal Tennis offers training programmes for all ages — from Mini Tennis for 4–6 year olds to competitive adult coaching — plus padel courts, a pool, and free parking. A great-value option on the eastern side of Marbella.","amenities":["Parking","Showers","Bar","Swimming Pool","Free Wi-Fi","Coaching"],"website":"http://www.royaltennisclub.com","bookingUrl":"https://playtomic.io","featured":false,"rating":4.2,"reviewCount":301,"image":"https://lh3.googleusercontent.com/gps-cs-s/AHVAweoSi-_0lVNEZm5qviIVetMcZ3Zyz7glFjHEeJQhebExzv04cd13L4CDzk0H9hoT4c60QeHIIqfo3E-xAxjHw_Gwgel_T5lBt3TKnna6Lln-p_-OMZy_kOwsAK7nfCN6eEstT4bo=w800-h500-k-no"},{"slug":"rafa-nadal-tennis-center-marbella","name":"Rafa Nadal Tennis Center Marbella","area":"Marbella Este","courts":6,"indoor":false,"outdoor":true,"priceFrom":20,"priceTo":35,"surface":"Clay / Hard","phone":"+34 952 76 88 00","lat":36.491,"lng":-4.773,"address":"Av. Zurita, s/n, 29604 Marbella, Málaga","hours":"Daily 09:00–21:00","description":"The Marbella outpost of Rafa Nadal's global academy network, bringing world-class coaching methodology to the Costa del Sol. The centre offers high-performance training camps and individual lessons on premium clay and hard courts, with racket sports including padel. A must-visit for serious players who want to train in the Nadal Academy tradition.","amenities":["Parking","Showers","Pro Shop","Racket Rental","Gym","Coaching"],"website":"https://international.rafanadalacademy.com/marbella/","bookingUrl":"https://playtomic.io","featured":true,"rating":4.8,"reviewCount":51,"image":"https://images.unsplash.com/photo-1622279457486-62dcc4a431d6?w=800&q=80&auto=format&fit=crop"},{"slug":"los-naranjos-padel","name":"Los Naranjos Padel Club","area":"Puerto Banús","courts":18,"indoor":true,"outdoor":true,"priceFrom":14,"priceTo":22,"surface":"Artificial Grass","phone":"+34 694 225 707","lat":36.497,"lng":-4.955,"address":"Av. Valle Inclán, 41, 29660 Nueva Andalucía, Marbella","hours":"Daily 07:30–22:30","description":"The largest padel club in Andalusia, just five minutes from Puerto Banús marina. Los Naranjos boasts 18 courts across indoor and outdoor settings — including one World Padel Tour competition court, four fully covered indoor courts, and a dedicated solo practice facility. With a professional coaching academy and pickleball courts added in 2024, this is the most comprehensive padel destination on the Costa del Sol.","amenities":["Parking","Showers","Bar","Pro Shop","Racket Rental","Physiotherapy","Coaching"],"website":"https://losnaranjospadel.com","bookingUrl":"https://playtomic.io","featured":false,"image":"https://images.unsplash.com/photo-1554068865-24cecd4e34b8?w=800&q=80&auto=format&fit=crop"},{"slug":"villa-padierna-padel","name":"Villa Padierna Racquet Club","area":"Estepona","courts":15,"indoor":false,"outdoor":true,"priceFrom":22,"priceTo":38,"surface":"Artificial Grass","phone":"+34 606 059 391","lat":36.468,"lng":-5.042,"address":"Calle Adriano, Urb. Costalita, 29688 Estepona, Málaga","hours":"Mon–Sat 10:00–23:00, Sun 10:00–15:00","description":"The most luxurious padel experience on the Costa del Sol. Fifteen courts spread across three areas within the grounds of the five-star Villa Padierna Palace hotel. Five-star service extends to every aspect of play — private coaching, bespoke racket fitting, and post-match spa treatments are all on offer.","amenities":["Parking","Showers","Restaurant","Bar","Pro Shop","Racket Rental","Physiotherapy","Gym","Swimming Pool","Spa","Coaching"],"website":"https://www.villapadierna.es/en/padel/","bookingUrl":"https://playtomic.io","featured":false,"image":"https://images.unsplash.com/photo-1602211844066-d3bb556e983b?w=800&q=80&auto=format&fit=crop"},{"slug":"real-club-padel-marbella","name":"Real Club Padel Marbella","area":"Marbella Centro","courts":6,"indoor":false,"outdoor":true,"priceFrom":14,"priceTo":22,"surface":"Artificial Grass","phone":"+34 651 439 395","lat":36.496,"lng":-4.977,"address":"C. Río Amazonas, s/n, 29660 Marbella, Málaga","hours":"Mon–Sat 07:00–23:00, Sun 08:00–23:00","description":"Marbella's most vibrant padel community. Real Club Padel Marbella combines six next-generation courts with an on-site gym and spa. Weekly leagues, ladies' sessions, and junior development programmes run year-round — making this the natural choice for players who want great padel and great company in central Marbella.","amenities":["Parking","Showers","Bar","Pro Shop","Racket Rental","Gym","Spa","Coaching"],"website":"https://realclubpadelmarbella.com","bookingUrl":"https://playtomic.io","featured":true,"image":"https://images.unsplash.com/photo-1560012057-4372e14c5085?w=800&q=80&auto=format&fit=crop"},{"slug":"los-monteros-racket-club","name":"Los Monteros Racket Club","area":"Marbella Este","courts":6,"indoor":false,"outdoor":true,"priceFrom":12,"priceTo":20,"surface":"Artificial Grass","phone":"+34 680 556 378","lat":36.504,"lng":-4.8,"address":"Calle del Lince, Urb. Los Monteros, 29603 Marbella, Málaga","hours":"Mon–Sat 09:00–22:00, Sun 09:00–15:00","description":"Tucked within the exclusive Los Monteros estate east of Marbella town, this elegant racket club offers six glass padel courts in a tranquil beachside setting. Popular with residents of the surrounding villas and guests at the Kimpton Los Monteros hotel, the club has a genuine members feel with friendly staff and competitive rates.","amenities":["Parking","Showers","Bar","Racket Rental","Swimming Pool","Coaching"],"website":"https://www.monteros.com/en/racket/","bookingUrl":"https://playtomic.io","featured":false,"image":"https://images.unsplash.com/photo-1595435934249-5df7ed86e1c0?w=800&q=80&auto=format&fit=crop"}]}]]}],"$L6"],null,"$L7"]}],{},null,false]},null,false]},null,false],"$L8",false]],"m":"$undefined","G":["$9",[]],"s":false,"S":true}
